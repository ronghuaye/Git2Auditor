<Window x:Class="Git2Auditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:viewmodels="clr-namespace:Git2Auditor.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="Git2Auditor - 开源协作数据监控 Agent" Height="900" Width="1500"
        Background="#1E1E1E" Foreground="#D4D4D4" FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:SoloHeroToBrushConverter x:Key="SoloHeroToBrushConverter"/>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部配置区 -->
        <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- PAT 和 全局操作 -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="700"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="GitHub PAT (Token):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Pat, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                    
                    <Button Grid.Column="3" Content="导入名单 (Import)" Command="{Binding ImportStudentsCommand}" Margin="10,0,0,0" Padding="20" Cursor=""/>
                    <Button Grid.Column="4" Content="并发抓取 (Fetch)" Command="{Binding FetchDataCommand}" Margin="10,0,0,0"  Padding="20"/>
                    <Button Grid.Column="5" Content="导出台账 (Export)" Command="{Binding ExportExcelCommand}" Margin="10,0,0,0"  Padding="20" Cursor="Hand"/>
                </Grid>

                <!-- 各小组仓库配置 -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding GroupConfigs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="0,-10,-10,0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#333333" BorderThickness="1" Margin="0,0,10,0" Padding="10" Background="#252526">
                                <StackPanel>
                                    <TextBlock Text="{Binding GroupId, StringFormat='第 {0} 小组仓库配置'}" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="Owner:" VerticalAlignment="Center" Margin="0,0,5,5" FontSize="11"/>
                                        <TextBox Grid.Column="1" Text="{Binding RepoOwner, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5" FontSize="11" Background="#1E1E1E"/>
                                        
                                        <TextBlock Grid.Row="1" Text="Repo:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RepoName, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Background="#1E1E1E"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- 主体数据区 -->
        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 界面上层：宏观看板 (雷达图) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                
                <Border BorderBrush="#333333" BorderThickness="1" Background="#252526" Height="300">
                    <Grid>
                        <TextBlock Text="各小组整体架构健康度 (多维对抗)" Foreground="#888888" Margin="15" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <lvc:PolarChart Series="{Binding RadarSeries}" AngleAxes="{Binding RadarAxes}" RadiusAxes="{Binding RadiusAxes}" TooltipTextPaint="{Binding TooltipTextPaint}" Margin="20,40,20,20" />
                    </Grid>
                </Border>

                <!-- 组别选择器 -->
                <Border Grid.Column="1" BorderBrush="#333333" BorderThickness="1" Background="#252526" Margin="15,0,0,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="穿透分析 (选择小组)" Foreground="#888888" Margin="0,0,0,15"/>
                        <ComboBox ItemsSource="{Binding GroupHealthList}" SelectedItem="{Binding SelectedGroup}" 
                                  Background="#1E1E1E" Foreground="#D4D4D4" BorderBrush="#333333" Padding="8">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GroupId, StringFormat='第 {0} 小组个人明细'}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Margin="0,20,0,0" DataContext="{Binding SelectedGroup}">
                            <TextBlock Text="选中组架构概览：" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding CICDScore, StringFormat='CI/CD 综合得分: {0}'}" Margin="0,5"/>
                            <TextBlock Text="{Binding PRActivityScore, StringFormat='PR 活跃度: {0}分'}" Margin="0,5"/>
                            <TextBlock Text="{Binding CodeReviewScore, StringFormat='代码审核评分: {0}分'}" Margin="0,5"/>
                            <TextBlock Text="{Binding DocumentationScore, StringFormat='文档完善度: {0}%'}" Margin="0,5"/>
                            <TextBlock Text="{Binding IssueScore, StringFormat='Issue 管理: {0}分'}" Margin="0,5"/>
                            <TextBlock Text="{Binding GroupHealthScore, StringFormat='⭐ 综合得分: {0:F1}'}" FontWeight="Bold" Margin="0,15,0,0" Foreground="DarkOrange" FontSize="16"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 极简视觉分割线 -->
            <Border Grid.Row="1" Height="1" Background="#333333" VerticalAlignment="Center" Margin="0,7"/>

            <!-- 界面下层：微观穿透 (个人明细表格) -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding DisplayedRecords}"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Background="Transparent" RowBackground="#1E1E1E" AlternatingRowBackground="#252526"
                      Foreground="#D4D4D4" BorderBrush="#333333" BorderThickness="1"
                      GridLinesVisibility="All" HorizontalGridLinesBrush="#333333" VerticalGridLinesBrush="#333333"
                      HeadersVisibility="Column" SelectionMode="Single">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <!-- 通过 Converter 实现单体英雄主义高亮预警 -->
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <!-- 当行所属小组与选中小组匹配时高亮 -->
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource GroupMatchToHighlightConverter}">
                                        <Binding Path="Student.GroupId"/>
                                        <Binding Path="DataContext.SelectedGroup.GroupId" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="BorderThickness" Value="0,1,0,1"/>
                            </DataTrigger>
                            
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="组别" Binding="{Binding Student.GroupId}" Width="60"/>
                    <DataGridTextColumn Header="姓名" Binding="{Binding Student.Name}" Width="80"/>
                    <DataGridCheckBoxColumn Header="组长" Binding="{Binding Student.IsLeader}" Width="50"/>
                    <DataGridTextColumn Header="GitHubID" Binding="{Binding Student.GitHubUsername}" Width="120"/>
                    <DataGridTextColumn Header="Commits" Binding="{Binding Data.CommitsCount}" Width="80"/>
                    <DataGridTextColumn Header="分配Issue" Binding="{Binding Data.IssuesAssigned}" Width="90"/>
                    <DataGridTextColumn Header="解决率" Binding="{Binding Data.IssueResolveRate, StringFormat={}{0}%}" Width="80"/>
                    <DataGridTextColumn Header="参与PR" Binding="{Binding Data.PrsParticipated}" Width="80"/>
                    <DataGridTextColumn Header="健康度" Binding="{Binding Data.HealthScore}" Width="80"/>
                    <DataGridTextColumn Header="备注" Binding="{Binding Remarks}" Width="*" Foreground="#E51400"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Width="1" Background="#333333" HorizontalAlignment="Center" Margin="0,10"/>

            <Border Grid.Column="2" BorderBrush="#333333" BorderThickness="1" Background="#252526">
                <Grid>
                    <TextBlock Text="个体协作多维画像" Foreground="#888888" Margin="15" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <lvc:PolarChart Series="{Binding RadarSeries}" AngleAxes="{Binding RadarAxes}" RadiusAxes="{Binding RadiusAxes}" TooltipTextPaint="{Binding TooltipTextPaint}" Margin="20,40,20,20" />
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" Background="#007ACC" Foreground="#FFFFFF" Margin="-20,15,-20,-20" Padding="20,5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar IsIndeterminate="{Binding IsBusy}" Width="100" Height="4" 
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
